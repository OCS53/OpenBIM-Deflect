{
  "openapi": "3.1.0",
  "info": {
    "title": "OpenBIM-Deflect API",
    "description": "IFC 업로드 후 스파이크 파이프라인(IFC→Gmsh→CalculiX) 실행",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/analyze": {
      "post": {
        "summary": "Analyze Ifc",
        "operationId": "analyze_ifc_api_v1_analyze_post",
        "parameters": [
          {
            "name": "mesh_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 0.25,
              "title": "Mesh Size"
            }
          },
          {
            "name": "young",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 210000.0,
              "title": "Young"
            }
          },
          {
            "name": "poisson",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 0.3,
              "title": "Poisson"
            }
          },
          {
            "name": "load_z",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 10000.0,
              "title": "Load Z"
            }
          },
          {
            "name": "run_ccx",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true,
              "title": "Run Ccx"
            }
          },
          {
            "name": "geometry_strategy",
            "in": "query",
            "required": false,
            "schema": {
              "enum": [
                "auto",
                "stl_classify",
                "stl_raw",
                "occ_bbox"
              ],
              "type": "string",
              "default": "auto",
              "title": "Geometry Strategy"
            }
          },
          {
            "name": "boundary_mode",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "enum": [
                    "FIX_MIN_Z_LOAD_MAX_Z",
                    "FIX_MIN_Y_LOAD_MAX_Y",
                    "FIX_MIN_Z_LOAD_TOP_X",
                    "FIX_MIN_Z_LOAD_TOP_Y"
                  ],
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Boundary Mode"
            }
          },
          {
            "name": "first_product_only",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "First Product Only"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_analyze_ifc_api_v1_analyze_post"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyzeResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs/{job_id}/artifacts/{filename}": {
      "get": {
        "summary": "Download Artifact",
        "operationId": "download_artifact_api_v1_jobs__job_id__artifacts__filename__get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          },
          {
            "name": "filename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Filename"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs": {
      "post": {
        "summary": "Create Pipeline Job",
