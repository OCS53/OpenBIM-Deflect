            }
          },
          {
            "name": "young",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 210000.0,
              "title": "Young"
            }
          },
          {
            "name": "poisson",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 0.3,
              "title": "Poisson"
            }
          },
          {
            "name": "load_z",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 10000.0,
              "title": "Load Z"
            }
          },
          {
            "name": "run_ccx",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true,
              "title": "Run Ccx"
            }
          },
          {
            "name": "geometry_strategy",
            "in": "query",
            "required": false,
            "schema": {
              "enum": [
                "auto",
                "stl_classify",
                "stl_raw",
                "occ_bbox"
              ],
              "type": "string",
              "default": "auto",
              "title": "Geometry Strategy"
            }
          },
          {
            "name": "boundary_mode",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "enum": [
                    "FIX_MIN_Z_LOAD_MAX_Z",
                    "FIX_MIN_Y_LOAD_MAX_Y",
                    "FIX_MIN_Z_LOAD_TOP_X",
                    "FIX_MIN_Z_LOAD_TOP_Y"
                  ],
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Boundary Mode"
            }
          },
          {
            "name": "first_product_only",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "First Product Only"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_create_pipeline_job_api_v1_jobs_post"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobCreatedResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs/{job_id}": {
      "get": {
        "summary": "Get Job Status",
        "operationId": "get_job_status_api_v1_jobs__job_id__get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobStatusResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnalyzeResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "status": {
            "type": "string",
            "const": "completed",
            "title": "Status",
            "default": "completed"
          },
          "artifacts": {
            "items": {
              "$ref": "#/components/schemas/ArtifactInfo"
            },
            "type": "array",
            "title": "Artifacts"
          },
          "pipeline_report": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Pipeline Report",
            "description": "pipeline_report.json 내용 (Gmsh 전략·geometry_strategy 등)"
          },
          "fe_results": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/FeResultsPayload"
              },
              {
                "type": "null"
              }
            ],
            "description": "FRD 기반 변위·응력 요약 (fe_results.json)"
          },
          "log_tail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Log Tail",
            "description": "파이프라인 표준출력 마지막 일부 (디버그용)"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "artifacts"
        ],
        "title": "AnalyzeResponse"
      },
      "ArtifactInfo": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "size_bytes": {
            "type": "integer",
            "title": "Size Bytes",
            "description": "바이트 크기"
          },
          "url": {
            "type": "string",
            "title": "Url",
            "description": "GET으로 내려받을 경로 (호스트 기준)"
          }
        },
        "type": "object",
        "required": [
          "name",
          "size_bytes",
          "url"
        ],
        "title": "ArtifactInfo"
      },
      "Body_analyze_ifc_api_v1_analyze_post": {
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "title": "File",
            "description": "IFC SPF (.ifc)"
          },
          "analysis_spec": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Analysis Spec",
            "description": "AnalysisInputV1 JSON 문자열 (선택, docs/LOAD-MODEL-AND-INP.md)"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_analyze_ifc_api_v1_analyze_post"
      },
      "Body_create_pipeline_job_api_v1_jobs_post": {
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
